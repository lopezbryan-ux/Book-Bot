{
  "name": "book-bot",
  "version": "1.0.0",
  "description": "Bot for my friends to use to view, store, nominate our books",
  "main": "dist/index.js",
  "scripts": {
  "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "deploy-commands": "node dist/deploy-commands.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "cleanrun": "git pull && rm -rf dist && npm run build && npm run deploy-commands && node dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lopezbryan-ux/Book-Bot.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/lopezbryan-ux/Book-Bot/issues"
  },
  "homepage": "https://github.com/lopezbryan-ux/Book-Bot#readme",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "discord.js": "^14.26.4",
    "dotenv": "^17.4.2",
    "mongodb": "^7.3.0"
  }
}
